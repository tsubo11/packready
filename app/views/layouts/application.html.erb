<!DOCTYPE html>
<html>
  <head>
    <title>PackReady</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta property="og:title" content="PackReady">
    <meta property="og:type" content="website">
    <meta property="og:image" content="<%= image_url('packready_ogp.png') %>">
    <meta property="og:url" content="https://packready.jp">
    <meta property="og:description" content="タイミング別に整理するパッキング支援アプリ">
    <meta property="og:site_name" content="PackReady">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_include_tag "application", "data-turbo-track": "reload", type: "module" %>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/dist/tabler-icons.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@700;800;900&family=DM+Sans:wght@400;500&display=swap" rel="stylesheet">

    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-7SMZSM6XYK"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-7SMZSM6XYK');
    </script>
  </head>

  <body>

    <%# ナビゲーションバー %>
    <nav class="flex items-center justify-between px-5 py-3 bg-brown">
      <%= link_to root_path, class: "flex items-center gap-2" do %>
        <div class="flex items-center justify-center w-7 h-7 rounded-lg bg-gold">
          <svg width="25" height="25" viewBox="0 0 48 48" fill="none">
            <path d="M17 16C17 12 20 10 24 10C28 10 31 12 31 16"
              stroke="#3d2b1f" stroke-width="2.5" stroke-linecap="round"/>
            <rect x="8" y="16" width="32" height="22" rx="4"
              fill="rgba(61,43,31,0.1)" stroke="#3d2b1f" stroke-width="2.5"/>
            <polyline points="16,28 21,34 32,22"
                  stroke="#3d2b1f" stroke-width="3"
                  stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <span class="font-nunito font-black text-base text-cream">Pack<span class="text-gold">Ready</span></span>
      <% end %>

      <% if user_signed_in? %>
        <%= link_to "ログアウト", destroy_user_session_path,
          data: { turbo_method: :delete },
          class: "px-4 py-2 rounded-lg bg-gold text-brown text-sm font-bold" %>
      <% else %>
        <div class="flex gap-2">
          <%= link_to "新規登録", new_user_registration_path,
            class: "px-4 py-2 rounded-lg border border-gold text-gold text-sm font-semibold" %>
          <%= link_to "ログイン", new_user_session_path,
            class: "px-4 py-2 rounded-lg bg-gold text-brown text-sm font-bold" %>
        </div>
      <% end %>
    </nav>
  
    <% if notice %>
    <div style="background-color: rgba(201, 168, 76, 0.1); border-bottom: 1px solid rgba(201, 168, 76, 0.3); padding: 12px 20px; font-size: 0.875rem; color: #3d2b1f;"><%= notice %></div>
    <% end %>
    
    <%= yield %>
  </body>
</html>
